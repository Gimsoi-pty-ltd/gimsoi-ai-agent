# --- GIMSOI AI AGENT: BACKEND CONFIGURATION ---

# The Port the server will run on (Default: 3400)
PORT=3400

# Your Google Gemini API Key 
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_api_key_here

# Database Configuration (if applicable)
# DATABASE_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/gimsoi

# Environment state (development, production, test)
NODE_ENV=development